{
  "name": "unifi-code-mode-mcp",
  "version": "0.2.0-beta.1",
  "description": "Code-mode MCP server for the UniFi Network Integration API and Site Manager (cloud) API. Two tools (search + execute) with QuickJS WASM sandbox plus an optional Cloudflare Workers entry. Single-user (env) and multi-user (per-request HTTP headers) modes.",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "unifi-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/spec',{recursive:true});for(const f of ['cloud-fallback.json','protect-fallback.json'])fs.copyFileSync('src/spec/'+f,'dist/spec/'+f);\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src/ scripts/ cf-worker/ --ext .ts",
    "lint:fix": "eslint src/ scripts/ cf-worker/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"scripts/**/*.ts\" \"cf-worker/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"scripts/**/*.ts\" \"cf-worker/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update-spec": "tsx scripts/update-spec.ts",
    "live-test": "tsx scripts/live-test.ts",
    "cf:dev": "wrangler dev --config cf-worker/wrangler.toml",
    "cf:deploy": "wrangler deploy --config cf-worker/wrangler.toml"
  },
  "keywords": [
    "unifi",
    "ubiquiti",
    "mcp",
    "model-context-protocol",
    "code-mode",
    "openapi",
    "site-manager",
    "network-api"
  ],
  "author": "Jamie van der Pijll <jmpijll@users.noreply.github.com> (https://github.com/jmpijll)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jmpijll/unifi-code-mode-mcp.git"
  },
  "homepage": "https://github.com/jmpijll/unifi-code-mode-mcp#readme",
  "bugs": {
    "url": "https://github.com/jmpijll/unifi-code-mode-mcp/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@cloudflare/codemode": "^0.3.4",
    "@cloudflare/workers-types": "^4.20260507.1",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv": "^17.0.0",
    "eslint": "^8.57.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "wrangler": "^3.90.0"
  },
  "dependencies": {
    "@apidevtools/json-schema-ref-parser": "^11.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "quickjs-emscripten": "^0.31.0",
    "undici": "^7.0.0",
    "zod": "^3.23.0"
  }
}
