{
  "openapi": "3.1.0",
  "info": {
    "title": "UniFi Protect Integration API (curated fallback)",
    "version": "fallback-1",
    "description": "Curated minimal schema for the most commonly used JSON-over-HTTP operations of the UniFi Protect Integration API. Used only when no Protect spec URL is reachable; the loader prefers Ubiquiti's official spec at https://apidoc-cdn.ui.com/protect/v<version>/integration.json. Reference docs: https://developer.ui.com/protect/v7.0.107/gettingstarted. The full surface (alarm-manager webhooks, files, RTSPS streams, talk-back sessions, subscribe/* WebSockets) is not in this fragment — set UNIFI_PROTECT_SPEC_URL to the official spec to broaden it."
  },
  "servers": [
    { "url": "/integration" }
  ],
  "tags": [
    { "name": "meta", "description": "Application metadata (use for version discovery)" },
    { "name": "cameras", "description": "Camera information and PTZ control" },
    { "name": "nvrs", "description": "NVR (Network Video Recorder) information" },
    { "name": "sensors", "description": "Environmental and motion sensors" },
    { "name": "lights", "description": "UniFi smart lights" },
    { "name": "chimes", "description": "Doorbell chimes" },
    { "name": "viewers", "description": "Display devices (UniFi Viewport)" },
    { "name": "liveviews", "description": "Saved camera live-view layouts" }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-API-Key"
      }
    }
  },
  "security": [{ "ApiKeyAuth": [] }],
  "paths": {
    "/v1/meta/info": {
      "get": {
        "operationId": "getProtectMetaInfo",
        "tags": ["meta"],
        "summary": "Get the Protect application version and metadata",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/cameras": {
      "get": {
        "operationId": "listCameras",
        "tags": ["cameras"],
        "summary": "List all cameras adopted by this Protect controller",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/cameras/{id}": {
      "get": {
        "operationId": "getCamera",
        "tags": ["cameras"],
        "summary": "Get a single camera by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/cameras/{id}/snapshot": {
      "get": {
        "operationId": "getCameraSnapshot",
        "tags": ["cameras"],
        "summary": "Get a JPEG snapshot URL or binary from a camera (check controller behaviour for response shape)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "highQuality", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/cameras/{id}/disable-mic-permanently": {
      "post": {
        "operationId": "disableCameraMicPermanently",
        "tags": ["cameras"],
        "summary": "Permanently disable a camera's microphone (one-way, irreversible)",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "204": { "description": "Disabled" } }
      }
    },
    "/v1/cameras/{id}/ptz/goto/{slot}": {
      "post": {
        "operationId": "cameraPtzGoto",
        "tags": ["cameras"],
        "summary": "Move a PTZ camera to a preset position",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "slot", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "204": { "description": "Accepted" } }
      }
    },
    "/v1/cameras/{id}/ptz/patrol/start/{slot}": {
      "post": {
        "operationId": "cameraPtzPatrolStart",
        "tags": ["cameras"],
        "summary": "Start a PTZ patrol routine on a camera",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } },
          { "name": "slot", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": { "204": { "description": "Accepted" } }
      }
    },
    "/v1/cameras/{id}/ptz/patrol/stop": {
      "post": {
        "operationId": "cameraPtzPatrolStop",
        "tags": ["cameras"],
        "summary": "Stop the active PTZ patrol routine on a camera",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "204": { "description": "Accepted" } }
      }
    },
    "/v1/nvrs": {
      "get": {
        "operationId": "listNvrs",
        "tags": ["nvrs"],
        "summary": "List NVRs (typically 1: the controller itself)",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/sensors": {
      "get": {
        "operationId": "listSensors",
        "tags": ["sensors"],
        "summary": "List all sensors adopted by this Protect controller",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/sensors/{id}": {
      "get": {
        "operationId": "getSensor",
        "tags": ["sensors"],
        "summary": "Get a single sensor by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/lights": {
      "get": {
        "operationId": "listLights",
        "tags": ["lights"],
        "summary": "List all UniFi smart lights",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/lights/{id}": {
      "get": {
        "operationId": "getLight",
        "tags": ["lights"],
        "summary": "Get a single light by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/chimes": {
      "get": {
        "operationId": "listChimes",
        "tags": ["chimes"],
        "summary": "List all doorbell chimes",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/chimes/{id}": {
      "get": {
        "operationId": "getChime",
        "tags": ["chimes"],
        "summary": "Get a single chime by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/viewers": {
      "get": {
        "operationId": "listViewers",
        "tags": ["viewers"],
        "summary": "List all viewer (Viewport) devices",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/viewers/{id}": {
      "get": {
        "operationId": "getViewer",
        "tags": ["viewers"],
        "summary": "Get a single viewer by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/liveviews": {
      "get": {
        "operationId": "listLiveviews",
        "tags": ["liveviews"],
        "summary": "List saved live-view layouts",
        "responses": { "200": { "description": "OK" } }
      }
    },
    "/v1/liveviews/{id}": {
      "get": {
        "operationId": "getLiveview",
        "tags": ["liveviews"],
        "summary": "Get a single live-view by id",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "OK" } }
      }
    }
  }
}
