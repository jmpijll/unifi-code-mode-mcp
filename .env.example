# =============================================================================
# UniFi Code-Mode MCP — Configuration
# =============================================================================
# Single-user mode: set the credentials below. The server reads these on startup
# and uses them for every request.
#
# Multi-user mode: leave the credentials below empty (or unset) and run with
# MCP_TRANSPORT=http. The MCP client must then send credentials in HTTP headers
# on each request:
#   X-Unifi-Local-Api-Key, X-Unifi-Local-Base-Url, X-Unifi-Local-Ca-Cert,
#   X-Unifi-Local-Insecure, X-Unifi-Cloud-Api-Key, X-Unifi-Cloud-Base-Url
#
# Sandbox surface (in unifi.local.*, unifi.cloud.*):
#   - unifi.local.<tag>.<op>(args)                     direct to the controller
#   - unifi.cloud.<tag>.<op>(args)                     Site Manager native (Hosts/Sites/…)
#   - unifi.cloud.network(consoleId).<tag>.<op>(args)  Network ops via cloud proxy
#   - unifi.local.protect.<tag>.<op>(args)             direct local Protect API (cameras, NVRs, …)
#   - unifi.cloud.protect(consoleId).<tag>.<op>(args)  Protect via cloud proxy (UNVERIFIED)
#
# See docs/multi-tenant.md, docs/usage.md, and docs/protect-design.md for details.
# =============================================================================

# ─── Transport ────────────────────────────────────────────────────────────
# stdio (default, single-user) | http (Streamable HTTP — required for multi-user)
MCP_TRANSPORT=stdio
MCP_HTTP_PORT=8000
# Comma-separated allowlist for HTTP transport (default: localhost only).
# Set to "*" to allow any origin (NOT recommended for production).
MCP_HTTP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# ─── UniFi Local Integration API (per-controller) ────────────────────────
# Base URL of your UniFi controller, e.g. https://192.168.1.1
# The server appends /proxy/network/integration/v1 internally.
UNIFI_LOCAL_BASE_URL=
UNIFI_LOCAL_API_KEY=
# Optional: path to a PEM file containing the CA bundle used to validate the
# controller's TLS certificate (e.g. your homelab root CA).
UNIFI_LOCAL_CA_CERT_PATH=
# Optional: skip TLS verification entirely. NOT recommended; use a CA cert.
# Accepted: true | false (default: false).
UNIFI_LOCAL_INSECURE=false

# ─── UniFi Site Manager API (cloud) ──────────────────────────────────────
# Cloud base URL — leave default unless Ubiquiti changes it.
UNIFI_CLOUD_BASE_URL=https://api.ui.com
UNIFI_CLOUD_API_KEY=

# ─── Spec Loading ────────────────────────────────────────────────────────
# Override the OpenAPI URL used for the local Network Integration spec. By
# default the server discovers the controller's app version via /v1/info and
# fetches:
#   https://apidoc-cdn.ui.com/network/v<version>/integration.json
UNIFI_LOCAL_SPEC_URL=

# Override the OpenAPI URL used for the Protect Integration spec. By default
# the server tries Ubiquiti's CDN (apidoc-cdn.ui.com/protect/v<version>/...)
# and falls back to a curated bundled fragment. Point at a full spec to
# broaden the surface (e.g. a community-maintained extraction).
UNIFI_PROTECT_SPEC_URL=

# If set to true, the loader is allowed to fall back to the public
# beezly/unifi-apis raw URL when no other source resolves. Off by default
# (third-party source, no explicit license — opt in only if you've reviewed it).
UNIFI_PROTECT_ALLOW_BEEZLY_FALLBACK=false

# Where to cache fetched OpenAPI specs on disk.
UNIFI_SPEC_CACHE_DIR=./src/spec/cache

# ─── Sandbox Limits ──────────────────────────────────────────────────────
# Maximum API calls per execute() invocation.
UNIFI_MAX_CALLS_PER_EXECUTE=50
